{
  "name": "codex-background-studio",
  "version": "0.2.1",
  "private": true,
  "description": "A reversible background manager for the Codex Windows desktop app.",
  "author": "Codex Background Studio contributors",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"tsc -p tsconfig.node.json -w --preserveWatchOutput\" \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:main": "tsc -p tsconfig.node.json",
    "dev:web": "vite --host 127.0.0.1",
    "build": "node -e \"require('fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p tsconfig.node.json && vite build",
    "test": "vitest run",
    "check": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit && vitest run",
    "package:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "image-size": "2.0.2",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "9.2.4",
    "cross-env": "10.1.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wait-on": "9.0.4"
  },
  "build": {
    "appId": "dev.codexbackground.studio",
    "productName": "Codex Background Studio",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
